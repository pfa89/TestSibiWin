# Copy to `.env` and fill in. `.env` is gitignored.

# Base URL of the site under test.
BASE_URL=https://test.sibi.win

# WordPress Application Password (Users > Profile > Application Passwords),
# for authenticated wp/v2 tests. Use the generated password (spaces allowed).
WP_USERNAME=
WP_APP_PASSWORD=

# WooCommerce REST API keys (WooCommerce > Settings > Advanced > REST API).
# Only needed for the authenticated WooCommerce tests.
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
